// Secrets.xcconfig  (committed — contains NO real secrets)
//
// Real keys live in Secrets.local.xcconfig, which is gitignored. To set yours:
//   1. cp Secrets.local.xcconfig.example Secrets.local.xcconfig
//   2. put your key in Secrets.local.xcconfig
// The optional include below loads that file when it exists and overrides the
// empty default. With no local file (e.g. a fresh clone or CI), the key stays
// empty and the app falls back to the open-source Piped extractor.

RAPIDAPI_KEY =

#include? "Secrets.local.xcconfig"
